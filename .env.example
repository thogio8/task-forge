# App
HTTP_PORT=8080

# Database
DB_HOST=db
DB_PORT=5432
DB_USER=taskforge
DB_PASSWORD=changeme
DB_NAME=taskforge
DB_SSL_MODE=disable

# Log
LOG_LEVEL=info # "debug", "info", "warn", "error"
LOG_FORMAT=json # "json", "text"

# Worker
WORKER_POOL_SIZE=5
WORKER_POLL_INTERVAL=2s
WORKER_BATCH_SIZE=10
WORKER_TASK_TIMEOUT=30s
WORKER_STALE_INTERVAL=30s
WORKER_STALE_DURATION=5m

# Shutdown
SHUTDOWN_TIMEOUT=30s